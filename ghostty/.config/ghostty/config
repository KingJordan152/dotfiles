# ==== Style ====
theme = TokyoNight
window-padding-balance = true
window-padding-x = 10
window-padding-y = 5
window-theme = ghostty
adjust-cursor-thickness = 2
adjust-underline-position = 4

# ==== Fonts ====
font-family = CaskaydiaCove Nerd Font
font-size = 15
font-feature = -calt

# ==== Editor Behavior ====
window-inherit-working-directory = false
tab-inherit-working-directory = false
split-inherit-working-directory = true
shell-integration = detect
shell-integration-features = true
mouse-hide-while-typing = true
cursor-style-blink = false
notify-on-command-finish = unfocused
quit-after-last-window-closed = true
title = " "

# ==== Linux-Only ====
gtk-toolbar-style = flat
app-notifications = no-clipboard-copy

# ==== Mac-Only ====
macos-titlebar-proxy-icon = hidden
macos-option-as-alt = left
font-thicken = true
window-colorspace = display-p3

# ==== Keybindings ====
keybind = ctrl+i=text:\x09
keybind = ctrl+[=text:\x1b
keybind = ctrl+tab=text:\x1b[9;5u
keybind = ctrl+shift+tab=text:\x1b[9;6u
keybind = ctrl+enter=unbind

# Use this optional config file to make platform-specific overrides
config-file = ?platform-overrides/config
